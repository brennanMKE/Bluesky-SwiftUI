PRODUCT_BUNDLE_IDENTIFIER = co.sstools.Bluesky
PRODUCT_NAME = Bluesky

SWIFT_VERSION = 6.0

SWIFT_APPROACHABLE_CONCURRENCY = YES
SWIFT_DEFAULT_ACTOR_ISOLATION = MainActor

MACOSX_DEPLOYMENT_TARGET = 15.6
IPHONEOS_DEPLOYMENT_TARGET = 18.6

SUPPORTED_PLATFORMS = iphoneos iphonesimulator macosx

SUPPORTS_MACCATALYST = NO

CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM = XV8BAAVZ6V
CODE_SIGN_ENTITLEMENTS = Bluesky-SwiftUI/Bluesky-SwiftUI.entitlements

TARGETED_DEVICE_FAMILY = 1,2

// iOS/iPadOS scene lifecycle and launch screen — required to avoid letterboxing
INFOPLIST_KEY_UIApplicationSceneManifest_Generation[sdk=iphone*] = YES
INFOPLIST_KEY_UIApplicationSupportsIndirectInputEvents[sdk=iphone*] = YES
INFOPLIST_KEY_UILaunchScreen_Generation[sdk=iphone*] = YES
INFOPLIST_KEY_UISupportedInterfaceOrientations = UIInterfaceOrientationPortrait

// Ensure each platform uses its own SDK root, not the macOS default
SDKROOT[sdk=iphone*] = iphoneos
SDKROOT[sdk=macos*] = macosx

// Framework rpath: iOS uses Frameworks/, macOS uses ../Frameworks/
LD_RUNPATH_SEARCH_PATHS[sdk=iphone*] = @executable_path/Frameworks
